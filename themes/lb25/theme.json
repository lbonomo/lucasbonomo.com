{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "800px",
			"wideSize": "1280px"
		},
		"color": {
			"palette": [
				{ "slug": "void", "color": "#F5FBFF", "name": "Sky Mist" },
				{ "slug": "deep-navy", "color": "#EAF4FF", "name": "Light Horizon" },
				{ "slug": "card-bg", "color": "#FFFFFF", "name": "Card White" },
				{ "slug": "electric", "color": "#0EA5FF", "name": "Vivid Azure" },
				{ "slug": "cool-white", "color": "#10233A", "name": "Ink Navy" },
				{ "slug": "muted-grey", "color": "#5D7288", "name": "Steel Blue" },
				{ "slug": "dim-grey", "color": "#8FA2B5", "name": "Cloud Grey" }
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Impact', 'Haettenschweiler', 'Arial Narrow Bold', 'Franklin Gothic Bold', sans-serif",
					"slug": "display",
					"name": "Display"
				},
				{
					"fontFamily": "'Trebuchet MS', 'Lucida Grande', 'Lucida Sans', sans-serif",
					"slug": "body",
					"name": "Body"
				},
				{
					"fontFamily": "'Courier New', 'Courier', monospace",
					"slug": "mono",
					"name": "Mono"
				}
			],
			"fontSizes": [
				{ "slug": "tiny", "size": "0.6rem", "name": "Tiny" },
				{ "slug": "small", "size": "0.75rem", "name": "Small" },
				{ "slug": "medium", "size": "1rem", "name": "Medium" },
				{ "slug": "large", "size": "1.25rem", "name": "Large" },
				{ "slug": "x-large", "size": "1.75rem", "name": "Extra Large" },
				{ "slug": "huge", "size": "clamp(2.5rem, 4vw, 3.5rem)", "name": "Huge" }
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		}
	},
	"styles": {
		"color": {
			"background": "#F5FBFF",
			"text": "#10233A"
		},
		"typography": {
			"fontFamily": "'Trebuchet MS', 'Lucida Grande', 'Lucida Sans', sans-serif",
			"fontSize": "1rem",
			"lineHeight": "1.6"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "'Impact', 'Haettenschweiler', 'Arial Narrow Bold', 'Franklin Gothic Bold', sans-serif",
					"lineHeight": "1.1"
				},
				"color": {
					"text": "#10233A"
				}
			},
			"link": {
				"color": {
					"text": "#0EA5FF"
				},
				":hover": {
					"color": {
						"text": "#0B79BF"
					}
				}
			}
		},
		"blocks": {
			"core/list": {
				"color": {
					"text": "#0EA5FF"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "0.65rem",
					"fontWeight": "500",
					"letterSpacing": "0.25em",
					"lineHeight": "1.4",
					"textTransform": "uppercase"
				}
			}
		},
		"spacing": {
			"blockGap": "1.5rem"
		}
	}
}